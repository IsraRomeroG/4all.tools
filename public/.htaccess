
ErrorDocument 404 /404.html

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Delete WWW
RewriteCond %{HTTP_HOST} ^www\.4all\.tools$ [NC]
RewriteRule ^(.*)$ https://4all.tools/$1 [R=301,L]

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect requested .html URLs to extensionless canonical URLs.
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[?\s] [NC]
  RewriteRule ^(.+?)\.html$ /$1 [R=301,L,NE]

  # Redirect requested URLs with trailing slashes to their canonical form.
  # THE_REQUEST prevents internal rewrites from triggering this redirect.
  RewriteCond %{THE_REQUEST} \s/+(.+?)/+[?\s] [NC]
  RewriteRule ^(.+?)/+$ /$1 [R=301,L,NE]

  # Serve Astro's file-format output from extensionless canonical URLs.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>
