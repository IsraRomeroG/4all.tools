---
import '@/styles/global.css';

import { LOCALES } from '@/i18n/config';
import type { Locale } from '@/i18n/types';

interface Props {
  locale: Locale;
  mainClass?: string;
}

const {
  locale,
  mainClass = 'min-h-screen',
} = Astro.props;

const localeDefinition = LOCALES[locale];
---

<!doctype html>
<html lang={localeDefinition.htmlLang} dir={localeDefinition.direction}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <slot name="head" />
  </head>
  <body class="bg-white text-slate-950 antialiased">
    <slot name="site-header" />

    <main id="main-content" class={mainClass}>
      <slot />
    </main>

    <slot name="site-footer" />
  </body>
</html>
