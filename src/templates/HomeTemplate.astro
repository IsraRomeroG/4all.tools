---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LanguageSwitcher from '@/components/navigation/LanguageSwitcher.astro';
import SeoHead from '@/components/seo/SeoHead.astro';
import type { HomePageModel } from './models/home';

interface Props {
  page: HomePageModel;
}

const { page } = Astro.props;
---

<BaseLayout locale={page.locale}>
  <LanguageSwitcher slot="site-header" model={page.languageSwitcher} />
  <Fragment slot="head">
    <SeoHead seo={page.seo} />
    <slot name="head" />
  </Fragment>

  <div class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-10 sm:px-6 lg:px-8" data-template="home">
    <header class="grid max-w-3xl gap-4" data-template-region="home-hero">
      <h1 class="text-3xl font-semibold tracking-normal text-slate-950">{page.title}</h1>
      {page.description && <p class="text-lg leading-8 text-slate-700">{page.description}</p>}
    </header>

    <section class="grid gap-4" aria-labelledby="home-search-heading" data-template-region="home-search">
      <h2 id="home-search-heading" class="sr-only">{page.messages.sections.search}</h2>
      <slot name="search" />
    </section>

    <section class="grid gap-4" aria-labelledby="home-featured-categories-heading" data-template-region="home-featured-categories">
      <h2 id="home-featured-categories-heading" class="sr-only">{page.messages.sections.featuredCategories}</h2>
      <slot name="featured-categories" />
    </section>

    <section class="grid gap-4" aria-labelledby="home-popular-tools-heading" data-template-region="home-popular-tools">
      <h2 id="home-popular-tools-heading" class="sr-only">{page.messages.sections.popularTools}</h2>
      <slot name="popular-tools" />
    </section>

    <section class="grid gap-4" aria-labelledby="home-recent-editorial-heading" data-template-region="home-recent-editorial">
      <h2 id="home-recent-editorial-heading" class="sr-only">{page.messages.sections.recentEditorial}</h2>
      <slot name="recent-editorial" />
    </section>
  </div>
</BaseLayout>
