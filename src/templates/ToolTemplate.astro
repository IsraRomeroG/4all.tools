---
import { getToolModule } from '@/features/tools/module-registry';
import SeoHead from '@/components/seo/SeoHead.astro';
import ToolLayout from '@/layouts/ToolLayout.astro';
import type { ToolPageModel } from './models/tool';

interface Props {
  page: ToolPageModel;
}

const { page } = Astro.props;
const EditorialContent = page.content.editorial.Content;
const toolModule = getToolModule(page.toolId);
const ToolComponent = toolModule.component;
const toolMessages = toolModule.getMessages(page.locale);
const toolInstanceId = `tool-${page.toolId}-${page.locale}`;
---

<ToolLayout locale={page.locale} workspaceLabel={page.messages.sections.toolWorkspace}>
  <Fragment slot="head">
    <SeoHead seo={page.seo} />
    <slot name="head" />
  </Fragment>

  <Fragment slot="page-header">
    <h1 class="text-3xl font-semibold tracking-normal text-slate-950" data-template-identity={page.toolId}>{page.content.title}</h1>
    <p class="max-w-3xl text-lg leading-8 text-slate-700">{page.content.description}</p>
  </Fragment>

  <div slot="tool" class="grid gap-4 rounded border border-slate-200 bg-white p-4" data-template-region="tool-executable">
    <ToolComponent
      locale={page.locale}
      messages={toolMessages}
      instanceId={toolInstanceId}
    />
    <slot name="tool" />
  </div>

  <div slot="content" class="grid gap-6" data-template-region="tool-editorial">
    <EditorialContent />
    <slot name="content" />
  </div>

  <div slot="related" class="grid gap-4" data-template-region="tool-related">
    <slot name="related" />
  </div>
</ToolLayout>
