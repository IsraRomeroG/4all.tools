---
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { BlogIndexPageModel } from './models/blog';

interface Props {
  page: BlogIndexPageModel;
}

const { page } = Astro.props;
---

<BaseLayout locale={page.locale}>
  <slot name="head" slot="head" />

  <div class="mx-auto grid w-full max-w-6xl gap-8 px-4 py-10 sm:px-6 lg:px-8" data-template="blog-index">
    <header class="grid max-w-3xl gap-4" data-template-region="blog-header">
      <h1 class="text-3xl font-semibold tracking-normal text-slate-950">{page.title}</h1>
      {page.description && <p class="text-lg leading-8 text-slate-700">{page.description}</p>}
    </header>

    <section class="grid gap-4" aria-labelledby="blog-featured-heading" data-template-region="blog-featured">
      <h2 id="blog-featured-heading" class="sr-only">Featured content</h2>
      <slot name="featured" />
    </section>

    <section class="grid gap-4" aria-labelledby="blog-articles-heading" data-template-region="blog-articles">
      <h2 id="blog-articles-heading" class="sr-only">Articles</h2>
      <slot name="articles" />
    </section>

    <aside class="grid gap-4" data-template-region="blog-categories">
      <slot name="categories" />
    </aside>
  </div>
</BaseLayout>
