---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import type { ArticlePageModel } from './models/blog';

interface Props {
  page: ArticlePageModel;
}

const { page } = Astro.props;
const legacyPage = page as unknown as { title?: string };
const title = page.content?.title ?? legacyPage.title ?? page.articleId;
const excerpt = page.content?.excerpt;
---

<ArticleLayout locale={page.locale}>
  <slot name="head" slot="head" />

  <Fragment slot="article-header">
    <p class="text-sm font-medium text-slate-600" data-template-identity={page.articleId}>{page.articleId}</p>
    <h1 class="text-3xl font-semibold tracking-normal text-slate-950">{title}</h1>
    {excerpt && <p class="text-lg leading-8 text-slate-700">{excerpt}</p>}
  </Fragment>

  <div slot="metadata" class="grid gap-2" data-template-region="article-metadata">
    <slot name="metadata" />
  </div>

  <div class="grid gap-6" data-template-region="article-content">
    <slot />
  </div>

  <div slot="related" class="grid gap-4" data-template-region="article-related">
    <slot name="related" />
  </div>
</ArticleLayout>
