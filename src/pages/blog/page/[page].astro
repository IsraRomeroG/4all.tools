---
import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
import { DEFAULT_LOCALE } from "@/lib/blog/config";
import {
  getBlogIndexAlternates,
  getPostsByLocale,
  getPublishedBlogPosts,
  paginateBlogPosts,
} from "@/lib/blog/content";

interface Props {
  page: number;
}

export async function getStaticPaths() {
  const allPosts = await getPublishedBlogPosts();
  const totalPages = paginateBlogPosts(getPostsByLocale(allPosts, DEFAULT_LOCALE), 1).totalPages;

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) },
      props: { page },
    };
  });
}

const { page } = Astro.props as Props;
const locale = DEFAULT_LOCALE;
const allPosts = await getPublishedBlogPosts();
const pagination = paginateBlogPosts(getPostsByLocale(allPosts, locale), page);
const alternates = await getBlogIndexAlternates(page);
---

<BlogIndexPage locale={locale} allPosts={allPosts} pagination={pagination} alternates={alternates} />
