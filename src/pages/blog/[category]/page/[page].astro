---
import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
import { DEFAULT_LOCALE, type BlogCategoryId } from "@/lib/blog/config";
import {
  getAvailableCategories,
  getCategoryAlternates,
  getPostsByCategory,
  getPublishedBlogPosts,
  paginateBlogPosts,
} from "@/lib/blog/content";

interface Props {
  categoryId: BlogCategoryId;
  page: number;
}

export async function getStaticPaths() {
  const allPosts = await getPublishedBlogPosts();

  return getAvailableCategories(allPosts, DEFAULT_LOCALE).flatMap((category) => {
    const totalPages = paginateBlogPosts(getPostsByCategory(allPosts, DEFAULT_LOCALE, category.id), 1).totalPages;
    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
      const page = index + 2;
      return {
        params: { category: category.slugs[DEFAULT_LOCALE], page: String(page) },
        props: { categoryId: category.id, page },
      };
    });
  });
}

const { categoryId, page } = Astro.props as Props;
const locale = DEFAULT_LOCALE;
const allPosts = await getPublishedBlogPosts();
const pagination = paginateBlogPosts(getPostsByCategory(allPosts, locale, categoryId), page);
const alternates = await getCategoryAlternates(categoryId, page);
---

<BlogIndexPage
  locale={locale}
  allPosts={allPosts}
  pagination={pagination}
  alternates={alternates}
  categoryId={categoryId}
/>
