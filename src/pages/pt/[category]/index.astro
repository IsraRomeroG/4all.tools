---
import CategoryTemplate from '@/templates/CategoryTemplate.astro';
import {
  composeRootCategoryAdapterPage,
  getDeliveryRouteRegistry,
} from '@/templates/composers';
import { createRootCategoryStaticPaths } from '@/routing/static-paths';
import type { StaticPathProps } from '@/routing/static-paths';

export const getStaticPaths = createRootCategoryStaticPaths({
  locale: 'pt',
  getRegistry: getDeliveryRouteRegistry,
});

interface Props extends StaticPathProps {}

const locale = 'pt' as const;
const { routeTarget } = Astro.props;
const routeRegistry = await getDeliveryRouteRegistry();
const page = await composeRootCategoryAdapterPage(locale, routeTarget, {
  routeRegistry,
});
---

<CategoryTemplate page={page} />
