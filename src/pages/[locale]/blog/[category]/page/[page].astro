---
import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
import { NON_DEFAULT_LOCALES, type BlogCategoryId, type Locale } from "@/lib/blog/config";
import {
  getAvailableCategories,
  getCategoryAlternates,
  getPostsByCategory,
  getPublishedBlogPosts,
  paginateBlogPosts,
} from "@/lib/blog/content";

interface Props {
  locale: Locale;
  categoryId: BlogCategoryId;
  page: number;
}

export async function getStaticPaths() {
  const allPosts = await getPublishedBlogPosts();

  return NON_DEFAULT_LOCALES.flatMap((locale) =>
    getAvailableCategories(allPosts, locale).flatMap((category) => {
      const totalPages = paginateBlogPosts(getPostsByCategory(allPosts, locale, category.id), 1).totalPages;
      return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
        const page = index + 2;
        return {
          params: { locale, category: category.slugs[locale], page: String(page) },
          props: { locale, categoryId: category.id, page },
        };
      });
    }),
  );
}

const { locale, categoryId, page } = Astro.props as Props;
const allPosts = await getPublishedBlogPosts();
const pagination = paginateBlogPosts(getPostsByCategory(allPosts, locale, categoryId), page);
const alternates = await getCategoryAlternates(categoryId, page);
---

<BlogIndexPage
  locale={locale}
  allPosts={allPosts}
  pagination={pagination}
  alternates={alternates}
  categoryId={categoryId}
/>
