---
import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
import { NON_DEFAULT_LOCALES, type BlogCategoryId, type Locale } from "@/lib/blog/config";
import {
  getAvailableCategories,
  getCategoryAlternates,
  getPostsByCategory,
  getPublishedBlogPosts,
  paginateBlogPosts,
} from "@/lib/blog/content";

interface Props {
  locale: Locale;
  categoryId: BlogCategoryId;
}

export async function getStaticPaths() {
  const allPosts = await getPublishedBlogPosts();

  return NON_DEFAULT_LOCALES.flatMap((locale) =>
    getAvailableCategories(allPosts, locale).map((category) => ({
      params: { locale, category: category.slugs[locale] },
      props: { locale, categoryId: category.id },
    })),
  );
}

const { locale, categoryId } = Astro.props as Props;
const allPosts = await getPublishedBlogPosts();
const pagination = paginateBlogPosts(getPostsByCategory(allPosts, locale, categoryId), 1);
const alternates = await getCategoryAlternates(categoryId, 1);
---

<BlogIndexPage
  locale={locale}
  allPosts={allPosts}
  pagination={pagination}
  alternates={alternates}
  categoryId={categoryId}
/>
