---
import BlogArticlePage from "@components/blog/BlogArticlePage.astro";
import { NON_DEFAULT_LOCALES } from "@/lib/blog/config";
import {
  getPostAlternates,
  getPostTranslations,
  getPostsByLocale,
  getPublishedBlogPosts,
  getRelatedPosts,
  type BlogPost,
} from "@/lib/blog/content";
import { render } from "astro:content";

interface Props {
  post: BlogPost;
}

export async function getStaticPaths() {
  const allPosts = await getPublishedBlogPosts();

  return NON_DEFAULT_LOCALES.flatMap((locale) =>
    getPostsByLocale(allPosts, locale).map((post) => ({
      params: { locale, category: post.categorySlug, slug: post.slug },
      props: { post },
    })),
  );
}

const { post } = Astro.props as Props;
const translations = await getPostTranslations(post.group);
const relatedPosts = await getRelatedPosts(post);
const alternates = getPostAlternates(translations);
const { Content } = await render(post.entry);
---

<BlogArticlePage post={post} translations={translations} relatedPosts={relatedPosts} alternates={alternates}>
  <Content />
</BlogArticlePage>
