---
import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
import { NON_DEFAULT_LOCALES, type Locale } from "@/lib/blog/config";
import {
  getBlogIndexAlternates,
  getPostsByLocale,
  getPublishedBlogPosts,
  paginateBlogPosts,
} from "@/lib/blog/content";

interface Props {
  locale: Locale;
}

export async function getStaticPaths() {
  const allPosts = await getPublishedBlogPosts();

  return NON_DEFAULT_LOCALES.filter((locale) => getPostsByLocale(allPosts, locale).length > 0).map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as Props;
const allPosts = await getPublishedBlogPosts();
const pagination = paginateBlogPosts(getPostsByLocale(allPosts, locale), 1);
const alternates = await getBlogIndexAlternates(1);
---

<BlogIndexPage locale={locale} allPosts={allPosts} pagination={pagination} alternates={alternates} />
