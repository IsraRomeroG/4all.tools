---
import "@styles/global.css";

interface Props {
  question: string;
  answer: string;
  open?: boolean;
}

const { question, answer, open = false } = Astro.props;
---

<details class="group border-b border-slate-200" open={open}>
  <summary
    class="flex min-h-[82px] cursor-pointer list-none items-center justify-between gap-5 text-[15px] font-[750] marker:hidden focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-blue-600/35 max-[760px]:min-h-[72px] [&::-webkit-details-marker]:hidden"
  >
    {question}
    <span
      class="relative size-6 shrink-0 rounded-full bg-slate-50 before:absolute before:top-[11px] before:left-[7px] before:h-[1.5px] before:w-2.5 before:bg-slate-600 before:content-[''] after:absolute after:top-[11px] after:left-[7px] after:h-[1.5px] after:w-2.5 after:rotate-90 after:bg-slate-600 after:transition-transform after:duration-200 after:content-[''] group-open:after:rotate-0 motion-reduce:after:transition-none"
      aria-hidden="true"
    ></span>
  </summary>
  <p class="mt-[-10px] mr-[55px] mb-[25px] text-[13px] leading-[1.75] text-slate-600">{answer}</p>
</details>
