---
import "@styles/global.css";
import AnnouncementPill from "./AnnouncementPill.astro";
import PopularTools from "./PopularTools.astro";
import ScrollHint from "./ScrollHint.astro";
import ToolSearch from "./ToolSearch.astro";
import TrustStats from "./TrustStats.astro";

interface LinkItem {
  label: string;
  href: string;
}

interface TrustStat {
  value: string;
  label: string;
}

interface SearchTool {
  label: string;
  href: string;
}

interface Props {
  title?: string;
  accentTitle?: string;
  description?: string;
  announcementBadge?: string;
  announcementLabel?: string;
  announcementHref?: string;
  popularTools?: LinkItem[];
  trustStats?: TrustStat[];
  searchTools?: SearchTool[];
}

const {
  title = "Every Tool You Need.",
  accentTitle = "One Search Away.",
  description = "Find calculators, converters, SEO tools, PDF utilities, developer tools and more.",
  announcementBadge = "New",
  announcementLabel = "Curated tool collections are here",
  announcementHref = "#collections",
  popularTools,
  trustStats,
  searchTools,
} = Astro.props;
---

<section
  class="relative grid min-h-svh items-center overflow-hidden bg-[linear-gradient(180deg,#fff_0%_72%,#f8fbff)] px-0 pt-[108px] pb-16 font-[Inter,ui-sans-serif,system-ui,sans-serif] leading-[1.6] text-slate-900 antialiased before:absolute before:inset-0 before:bg-[linear-gradient(#e8eef7_1px,transparent_1px),linear-gradient(90deg,#e8eef7_1px,transparent_1px)] before:bg-[size:56px_56px] before:opacity-[0.34] before:[mask-image:linear-gradient(to_bottom,transparent,#000_25%,transparent_80%)] max-[760px]:min-h-0 max-[760px]:pt-[105px] max-[760px]:pb-[62px] max-[760px]:before:hidden"
  id="hero"
>
  <div
    class="absolute top-[5%] left-[-260px] size-[500px] rounded-full bg-blue-400 opacity-[0.16] blur-[40px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute top-[14%] right-[-280px] size-[500px] rounded-full bg-violet-400 opacity-[0.16] blur-[40px]"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-[1] mx-auto w-[calc(100%-40px)] max-w-[1280px] text-center max-[760px]:w-[calc(100%-28px)] max-[760px]:max-w-[560px]"
  >
    <div class="mb-6 max-[760px]:mb-[19px]">
      <AnnouncementPill
        badge={announcementBadge}
        label={announcementLabel}
        href={announcementHref}
      />
    </div>

    <h1
      class="mx-auto my-0 max-w-[1000px] text-[clamp(50px,6.3vw,88px)] leading-[1.04] font-extrabold tracking-[-0.065em] max-[760px]:text-[clamp(42px,13vw,62px)] max-[760px]:leading-[1.02]"
    >
      {title}<br />
      <em class="text-blue-600 not-italic">{accentTitle}</em>
    </h1>

    <p
      class="mx-auto mt-6 mb-[34px] max-w-[680px] text-lg leading-[1.65] text-slate-600 max-[760px]:mt-[18px] max-[760px]:mb-6 max-[760px]:text-[15px]"
    >
      {description}
    </p>

    <ToolSearch tools={searchTools} />
    <PopularTools tools={popularTools} />
    <TrustStats stats={trustStats} />
  </div>

  <ScrollHint />
</section>
