---
import "@styles/global.css";
import Icon from "@components/icons/Icon.astro";

interface SearchTool {
  label: string;
  href: string;
}

interface Props {
  id?: string;
  placeholder?: string;
  buttonLabel?: string;
  submitTarget?: string;
  tools?: SearchTool[];
}

const defaultTools: SearchTool[] = [
  { label: "Percentage Calculator", href: "#featured" },
  { label: "PDF to Word", href: "#featured" },
  { label: "Image Compressor", href: "#featured" },
  { label: "JSON Formatter", href: "#featured" },
  { label: "Age Calculator", href: "#featured" },
  { label: "QR Code Generator", href: "#featured" },
  { label: "Loan Calculator", href: "#featured" },
  { label: "Word Counter", href: "#featured" },
  { label: "Meta Tag Generator", href: "#featured" },
  { label: "Regex Tester", href: "#featured" },
  { label: "Citation Generator", href: "#featured" },
  { label: "Invoice Maker", href: "#featured" },
];

const {
  id = "tool-search",
  placeholder = "What do you need to do?",
  buttonLabel = "Search",
  submitTarget = "#featured",
  tools = defaultTools,
} = Astro.props;

const resultsId = `${id}-results`;
---

<div class="relative mx-auto max-w-[900px]" data-tool-search data-submit-target={submitTarget}>
  <form
    class="flex h-[76px] items-center gap-3.5 rounded-full border border-[#dbe4f0] bg-white p-2 pl-[25px] shadow-[0_20px_55px_#2563eb21,0_2px_8px_#0f172a0f] transition-[border-color,box-shadow] duration-200 focus-within:border-[#93b4f8] focus-within:shadow-[0_24px_65px_#2563eb33,0_0_0_4px_#2563eb14] motion-reduce:transition-none max-[760px]:h-[62px] max-[760px]:gap-[9px] max-[760px]:rounded-[18px] max-[760px]:p-1.5 max-[760px]:pl-[17px]"
    role="search"
    data-search-form
  >
    <Icon name="search" class="size-6 shrink-0 text-blue-600 max-[760px]:size-5" />
    <label class="sr-only" for={id}>Search all tools</label>
    <input
      class="min-w-0 flex-1 border-0 bg-transparent text-[17px] text-slate-900 outline-0 placeholder:text-slate-400 max-[760px]:text-[15px]"
      id={id}
      type="search"
      autocomplete="off"
      placeholder={placeholder}
      aria-controls={resultsId}
      aria-expanded="false"
      data-search-input
    />
    <span class="rounded-md border border-slate-200 bg-slate-50 px-1.5 py-0.5 text-[11px] leading-[18px] text-slate-400 max-[760px]:hidden">
      &#8984; K
    </span>
    <button
      class="inline-flex min-h-[58px] cursor-pointer items-center justify-center rounded-full border-0 bg-blue-600 px-7 font-bold text-white [font:inherit] transition-[background-color,transform,box-shadow] duration-200 hover:-translate-y-px hover:bg-blue-700 hover:shadow-[0_10px_22px_#2563eb33] focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-blue-600/35 motion-reduce:transform-none motion-reduce:transition-none max-[760px]:hidden"
      type="submit"
    >
      {buttonLabel}
    </button>
  </form>

  <div
    class="absolute top-[calc(100%+10px)] right-5 left-5 z-10 hidden rounded-[20px] border border-slate-200 bg-white p-2 text-left shadow-[0_18px_50px_rgba(15,23,42,0.08)] data-[visible=true]:block max-[760px]:right-0 max-[760px]:left-0"
    id={resultsId}
    aria-live="polite"
    data-search-results
    data-visible="false"
  >
    {
      tools.map(({ label, href }) => (
        <a
          class="hidden justify-between rounded-[11px] px-[13px] py-[11px] font-semibold text-slate-900 no-underline hover:bg-slate-50 hover:text-blue-600 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-blue-600/35"
          href={href}
          data-search-result
          data-label={label.toLowerCase()}
        >
          <span>{label}</span>
          <small class="font-medium text-slate-400">Open tool &rarr;</small>
        </a>
      ))
    }
    <p class="m-2 hidden text-slate-600" data-no-results>No exact match yet. Try browsing our categories.</p>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-tool-search]").forEach((search) => {
    const form = search.querySelector<HTMLFormElement>("[data-search-form]");
    const input = search.querySelector<HTMLInputElement>("[data-search-input]");
    const results = search.querySelector<HTMLElement>("[data-search-results]");
    const links = Array.from(search.querySelectorAll<HTMLAnchorElement>("[data-search-result]"));
    const noResults = search.querySelector<HTMLElement>("[data-no-results]");

    const updateResults = () => {
      if (!input || !results) return;

      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      links.forEach((link) => {
        const matches = Boolean(query) && visibleCount < 5 && link.dataset.label?.includes(query);
        link.classList.toggle("hidden", !matches);
        link.classList.toggle("flex", matches);
        if (matches) visibleCount += 1;
      });

      if (noResults) noResults.classList.toggle("hidden", !query || visibleCount > 0);
      results.dataset.visible = String(Boolean(query));
      input.setAttribute("aria-expanded", String(Boolean(query)));
    };

    input?.addEventListener("input", updateResults);
    input?.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        input.value = "";
        updateResults();
        input.blur();
      }
    });

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const firstResult = links.find((link) => !link.classList.contains("hidden"));
      if (firstResult) {
        firstResult.click();
        return;
      }

      const target = search.dataset.submitTarget;
      if (target) document.querySelector(target)?.scrollIntoView({ behavior: "smooth" });
    });
  });

  document.addEventListener("keydown", (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      document.querySelector<HTMLInputElement>("[data-search-input]")?.focus();
    }
  });
</script>
