---
import "@styles/global.css";

interface PopularTool {
  label: string;
  href: string;
}

interface Props {
  label?: string;
  tools?: PopularTool[];
}

const defaultTools: PopularTool[] = [
  { label: "Percentage Calculator", href: "#featured" },
  { label: "PDF to Word", href: "#featured" },
  { label: "Image Compressor", href: "#featured" },
  { label: "JSON Formatter", href: "#featured" },
  { label: "Age Calculator", href: "#featured" },
];

const { label = "Popular today", tools = defaultTools } = Astro.props;
---

<div class="mt-[22px] flex flex-wrap items-center justify-center gap-2 text-xs text-slate-400 max-[760px]:mt-[17px] max-[760px]:justify-start">
  <span class="mr-[3px] font-bold text-slate-600 max-[760px]:w-full max-[760px]:text-left">{label}</span>
  {
    tools.map(({ label: toolLabel, href }, index) => (
      <a
        class:list={[
          "rounded-full border border-slate-200 bg-white/80 px-2.5 py-[5px] no-underline transition-[color,border-color] duration-200 hover:border-[#93b4f8] hover:text-blue-600 focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-blue-600/35 motion-reduce:transition-none",
          index >= 3 && "max-[760px]:hidden",
        ]}
        href={href}
      >
        {toolLabel}
      </a>
    ))
  }
</div>
