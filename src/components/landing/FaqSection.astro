---
import "@styles/global.css";
import FaqItem from "./FaqItem.astro";

interface FaqEntry {
  question: string;
  answer: string;
  open?: boolean;
}

interface Props {
  id?: string;
  kicker?: string;
  title?: string;
  contactEmail?: string;
  items?: FaqEntry[];
}

const defaultItems: FaqEntry[] = [
  {
    question: "Are all tools free?",
    answer:
      "Yes. Every tool on 4all.tools is free to use. We believe everyday utilities should be accessible without subscriptions or surprise paywalls.",
    open: true,
  },
  {
    question: "Will the tools work on my phone?",
    answer:
      "Yes. Every tool is designed and tested for phones, tablets and desktop browsers.",
    open: true,
  },
  {
    question: "Do I need an account?",
    answer:
      "No account is required. Open the tool you need and get straight to work.",
  },
  {
    question: "How often are tools added?",
    answer:
      "We add and improve tools regularly based on what people search for and suggest.",
  },
  {
    question: "Can I suggest a tool?",
    answer:
      "Absolutely. Send your idea to hello@4all.tools and tell us how it would help your workflow.",
  },
  {
    question: "Are my files and data private?",
    answer:
      "Our tools are designed to process data locally whenever possible. Files and inputs are never sold.",
  },
];

const {
  id = "faq",
  kicker = "Good to know",
  title = "Frequently asked questions",
  contactEmail = "hello@4all.tools",
  items = defaultItems,
} = Astro.props;
---

<section
  class="py-28 font-[Inter,ui-sans-serif,system-ui,sans-serif] leading-[1.6] text-slate-900 antialiased max-[760px]:py-[76px]"
  id={id}
>
  <div
    class="mx-auto grid w-[calc(100%-40px)] max-w-[1280px] grid-cols-[0.75fr_1.25fr] items-start gap-[100px] max-[760px]:w-[calc(100%-28px)] max-[760px]:max-w-[560px] max-[760px]:grid-cols-1 max-[760px]:gap-2.5"
  >
    <div
      class="sticky top-[120px] mb-[50px] max-[760px]:static max-[760px]:mb-8"
    >
      <span
        class="mb-2.5 block text-xs font-extrabold tracking-[0.13em] text-blue-600 uppercase"
        >{kicker}</span
      >
      <h2
        class="m-0 text-[clamp(36px,4vw,48px)] leading-[1.12] font-bold tracking-[-0.045em] max-[760px]:text-[34px]"
      >
        {title}
      </h2>
      <p
        class="mt-[17px] mb-0 text-[17px] leading-[1.7] text-slate-600 max-[760px]:text-sm"
      >
        Still curious? Send your question to
        <a
          class="font-bold text-blue-600 no-underline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-blue-600/35"
          href={`mailto:${contactEmail}`}
        >
          {contactEmail}
        </a>.
      </p>
    </div>

    <div class="border-t border-slate-200">
      {items.map((item) => <FaqItem {...item} />)}
    </div>
  </div>
</section>
