---
import "@styles/global.css";

interface TrustStat {
  value: string;
  label: string;
}

interface Props {
  stats?: TrustStat[];
}

const defaultStats: TrustStat[] = [
  { value: "10,000+", label: "useful tools" },
  { value: "100%", label: "free to use" },
  { value: "No signup", label: "just get it done" },
];

const { stats = defaultStats } = Astro.props;
---

<div class="mt-[50px] flex justify-center max-[760px]:mt-8">
  {
    stats.map(({ value, label }, index) => (
      <div
        class:list={[
          "min-w-[165px] border-r border-slate-200 px-[30px] max-[760px]:min-w-0 max-[760px]:flex-1 max-[760px]:px-2",
          index === stats.length - 1 && "border-r-0",
        ]}
      >
        <strong class="block text-[15px] max-[760px]:text-xs">{value}</strong>
        <span class="block text-[11px] text-slate-400 max-[760px]:text-[8px]">{label}</span>
      </div>
    ))
  }
</div>
