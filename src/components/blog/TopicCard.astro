---
import "@styles/global.css";

interface Props {
  symbol: string;
  label: string;
  count: string;
  href: string;
}

const { symbol, label, count, href } = Astro.props;
---

<a
  class="group flex min-w-0 flex-col rounded-[17px] border border-slate-200 bg-white p-4 no-underline transition-[border-color,box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-[0_16px_40px_rgba(15,23,42,0.08)] min-[1024px]:rounded-[19px] min-[1024px]:p-[18px]"
  href={href}
>
  <span class="grid size-[38px] place-items-center rounded-[11px] bg-blue-50 text-[13px] font-black text-blue-700">
    {symbol}
  </span>
  <strong class="mt-[13px] [overflow-wrap:anywhere] text-sm leading-[1.25] text-slate-900 group-hover:text-blue-700">
    {label}
  </strong>
  <span class="mt-1 text-[11px] text-slate-500">{count}</span>
</a>
