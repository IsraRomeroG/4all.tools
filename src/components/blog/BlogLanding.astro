const containerClass = "mx-auto w-[calc(100%-40px)] max-w-[1280px] min-[768px]:w-[calc(100%-64px)]";
const sectionClass = "py-[58px] min-[768px]:py-[72px] min-[1024px]:py-[88px]";
---

<div class="font-[Inter,ui-sans-serif,system-ui,sans-serif] leading-[1.6] text-slate-900 antialiased">
  {showHeader && <BlogHeader />}
  <main>
    <BlogHero />

    <section class={sectionClass} aria-labelledby="featured-guide-title">
      <div class={containerClass}>
        <p class="mb-2 text-xs font-extrabold tracking-[0.11em] text-blue-600 uppercase">Featured guide</p>
        <FeaturedGuide id="featured-guide-title" />
      </div>
    </section>

    <section class:list={[sectionClass, "border-y border-slate-200 bg-slate-50"]} aria-labelledby="topics-title">
      <div class={containerClass}>
        <BlogSectionHeading
          eyebrow="Find your subject"
          title="Browse by topic"
          description="Explore practical articles grouped by the types of tools people use every day."
          id="topics-title"
        />
        <div class="grid grid-cols-2 gap-[10px] min-[600px]:grid-cols-3 min-[768px]:grid-cols-4 min-[1024px]:grid-cols-6 min-[1024px]:gap-3">
          {topics.map((topic) => <TopicCard {...topic} />)}
        </div>
      </div>
    </section>

    <section class={sectionClass} aria-labelledby="latest-title">
      <div class={containerClass}>
        <BlogSectionHeading
          eyebrow="Recently published"
          title="Latest articles"
          description="Fresh tutorials, explainers and practical workflows from the 4all.tools team."
          id="latest-title"
          linkLabel="View all articles"
          linkHref="/blog/"
        />
        <div class="grid gap-[13px] min-[600px]:grid-cols-2 min-[1024px]:grid-cols-3 min-[1024px]:gap-4">
          {articles.map((article) => <ArticleCard {...article} />)}
        </div>
      </div>
    </section>

    <section class:list={[sectionClass, "border-y border-slate-200 bg-slate-50"]} aria-labelledby="category-guides-title">
      <div class={containerClass}>
        <BlogSectionHeading
          eyebrow="Structured learning"
          title="Practical guides by category"
          description="Start with a topic, understand the basics and move directly into useful workflows."
          id="category-guides-title"
        />
        <div class="grid gap-3.5 min-[768px]:grid-cols-2">
          {guides.map((guide) => <CategoryGuideCard {...guide} />)}
        </div>
      </div>
    </section>

    <section class={sectionClass} aria-labelledby="connected-title">
      <div class={containerClass}>
        <ConnectedLearning id="connected-title" items={connectedGuides} />
      </div>
    </section>

    <section class:list={[sectionClass, "border-y border-slate-200 bg-slate-50"]} aria-labelledby="popular-title">
      <div class={containerClass}>
        <BlogSectionHeading
          eyebrow="Reader favorites"
          title="Popular guides"
          description="Start with the tutorials readers use most often."
          id="popular-title"
        />
        <PopularGuides
          items={rankedGuides}
          weeklyTitle="The beginner's guide to free online tools"
          weeklyDescription="A practical overview of the most useful tools for students, marketers, developers, small businesses and everyday tasks."
          weeklyHref="/blog/productivity/beginners-guide-to-online-tools/"
        />
      </div>
    </section>

    <section class={sectionClass} aria-labelledby="clusters-title">
      <div class={containerClass}>
        <BlogSectionHeading
          eyebrow="Go deeper"
          title="Explore topic clusters"
          description="Organized paths for learning more about common tasks, tools and workflows."
          id="clusters-title"
        />
        <div class="grid gap-[13px] min-[600px]:grid-cols-2 min-[1024px]:grid-cols-3 min-[1024px]:gap-[15px]">
          {clusters.map((cluster) => <TopicClusterCard {...cluster} />)}
        </div>
      </div>
    </section>

    <Newsletter />
  </main>
  {showFooter && <BlogFooter />}
</div>
