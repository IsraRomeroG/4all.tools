---
import "@styles/global.css";
import Icon from "@components/icons/Icon.astro";
import type { ToolResult } from "./types";

interface Props {
  query?: string;
  results?: ToolResult[];
}

const defaultResults: ToolResult[] = [
  { symbol: "PDF", title: "PDF Compressor", description: "Reduce file size" },
  { symbol: "W", title: "PDF to Word", description: "Convert documents" },
  { symbol: "+", title: "Merge PDF", description: "Combine files" },
  { symbol: "/", title: "Split PDF", description: "Extract pages" },
];

const { query = "compress pdf", results = defaultResults } = Astro.props;
---

<div
  class="relative min-w-0 rounded-[22px] border border-blue-200/90 bg-white/70 p-3.5 min-[1024px]:p-5"
  aria-label="Example tool search interface"
>
  <div class="overflow-hidden rounded-[17px] border border-slate-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.1)]">
    <div class="flex gap-[5px] border-b border-slate-200 bg-slate-50 px-[13px] py-[11px]" aria-hidden="true">
      <i class="size-[7px] rounded-full bg-slate-300"></i>
      <i class="size-[7px] rounded-full bg-slate-300"></i>
      <i class="size-[7px] rounded-full bg-slate-300"></i>
    </div>
    <div class="p-4">
      <div class="flex items-center gap-2 rounded-[11px] border border-slate-200 bg-slate-50 px-3 py-[11px] text-xs font-bold text-slate-700">
        <Icon name="search" class="size-[15px] text-slate-500" />
        {query}
      </div>
      <div class="mt-[17px] mb-2 text-[10px] font-extrabold tracking-[0.1em] text-slate-400 uppercase">
        Related tools
      </div>
      <div class="grid gap-[7px]">
        {
          results.map(({ symbol, title, description }) => (
            <div class="flex items-center gap-[9px] rounded-[11px] border border-slate-200 bg-white p-[10px] text-xs font-bold">
              <span class="grid size-7 place-items-center rounded-lg bg-blue-50 text-[9px] font-black text-blue-600">
                {symbol}
              </span>
              <span>
                {title}
                <small class="mt-0.5 block text-[10px] font-medium text-slate-500">
                  {description}
                </small>
              </span>
              <span class="ml-auto text-slate-400" aria-hidden="true">&rarr;</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>
