---
import "@styles/global.css";
import BlogButton from "./BlogButton.astro";

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  href: string;
  buttonLabel?: string;
}

const {
  eyebrow = "Most useful this week",
  title,
  description,
  href,
  buttonLabel = "Read the guide",
} = Astro.props;
---

<article
  class="relative flex min-h-full flex-col items-start overflow-hidden rounded-[25px] bg-[linear-gradient(145deg,#0f172a,#1e3a5f)] p-[27px] text-white after:absolute after:right-[-18px] after:bottom-[-70px] after:text-[260px] after:leading-none after:font-black after:text-white/[0.07] after:content-['4']"
>
  <p class="relative z-[1] mb-2 text-xs font-extrabold tracking-[0.11em] text-blue-300 uppercase">{eyebrow}</p>
  <h3 class="relative z-[1] mt-2 mb-[13px] max-w-[390px] text-[clamp(27px,4vw,38px)] leading-[1.13] font-bold tracking-[-0.045em]">
    {title}
  </h3>
  <p class="relative z-[1] m-0 mb-6 max-w-[430px] text-sm leading-[1.7] text-slate-300">{description}</p>
  <BlogButton class="relative z-[1] mt-auto" href={href} label={buttonLabel} variant="light" arrow />
</article>
