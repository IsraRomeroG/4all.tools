---
import "@styles/global.css";
import BlogLogo from "./BlogLogo.astro";
import type { FooterGroup } from "./types";

interface Props {
  groups?: FooterGroup[];
}

const defaultGroups: FooterGroup[] = [
  {
    title: "Tools",
    links: [
      { label: "All tools", href: "/tools/" },
      { label: "Calculators", href: "/categories/calculators/" },
      { label: "PDF tools", href: "/categories/pdf/" },
      { label: "SEO tools", href: "/categories/seo/" },
      { label: "Developer tools", href: "/categories/developer-tools/" },
      { label: "Image tools", href: "/categories/image-tools/" },
    ],
  },
  {
    title: "Blog",
    links: [
      { label: "Latest articles", href: "/blog/" },
      { label: "Popular guides", href: "/blog/popular/" },
      { label: "SEO guides", href: "/blog/seo/" },
      { label: "PDF guides", href: "/blog/pdf/" },
      { label: "Calculator guides", href: "/blog/calculators/" },
      { label: "Developer guides", href: "/blog/developer-tools/" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Categories", href: "/categories/" },
      { label: "Collections", href: "/collections/" },
      { label: "New tools", href: "/new-tools/" },
      { label: "Sitemap", href: "/sitemap/" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/about/" },
      { label: "Contact", href: "/contact/" },
      { label: "Privacy", href: "/privacy/" },
      { label: "Terms", href: "/terms/" },
    ],
  },
];

const { groups = defaultGroups } = Astro.props;
---

<footer class="border-t border-slate-200 bg-slate-50 pt-[55px] pb-[22px]">
  <div class="mx-auto w-[calc(100%-40px)] max-w-[1280px] min-[768px]:w-[calc(100%-64px)]">
    <div class="grid gap-[34px] min-[1024px]:grid-cols-[0.8fr_1.2fr] min-[1024px]:gap-[70px]">
      <div>
        <BlogLogo />
        <p class="mt-[17px] mb-0 max-w-[340px] text-[13px] leading-[1.7] text-slate-500">
          Free online tools, calculators, converters and practical guides for everyday tasks.
        </p>
        <div class="mt-[18px] flex gap-[7px]">
          <a class="grid size-9 place-items-center rounded-[10px] border border-slate-200 bg-white text-[11px] font-extrabold text-slate-500 no-underline hover:border-blue-200 hover:text-blue-700" href="#" aria-label="4all.tools on X">X</a>
          <a class="grid size-9 place-items-center rounded-[10px] border border-slate-200 bg-white text-[11px] font-extrabold text-slate-500 no-underline hover:border-blue-200 hover:text-blue-700" href="#" aria-label="4all.tools on GitHub">GH</a>
          <a class="grid size-9 place-items-center rounded-[10px] border border-slate-200 bg-white text-[11px] font-extrabold text-slate-500 no-underline hover:border-blue-200 hover:text-blue-700" href="#" aria-label="4all.tools on LinkedIn">IN</a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-x-5 gap-y-7 min-[600px]:grid-cols-4">
        {
          groups.map(({ title, links }) => (
            <div>
              <h3 class="m-0 mb-[13px] text-xs font-bold tracking-[0.08em] text-slate-900 uppercase">{title}</h3>
              {links.map(({ label, href }) => (
                <a class="my-[9px] block text-xs text-slate-500 no-underline hover:text-blue-700" href={href}>
                  {label}
                </a>
              ))}
            </div>
          ))
        }
      </div>
    </div>
    <div class="mt-[38px] flex flex-col gap-2 border-t border-slate-200 pt-5 text-[11px] text-slate-400 min-[600px]:flex-row min-[600px]:items-center min-[600px]:justify-between">
      <span>&copy; 2026 4all.tools. All rights reserved.</span>
      <span class="flex gap-4">
        <a class="no-underline hover:text-blue-700" href="/privacy/">Privacy Policy</a>
        <a class="no-underline hover:text-blue-700" href="/terms/">Terms of Service</a>
      </span>
    </div>
  </div>
</footer>
