---
import "@styles/global.css";
import Icon from "@components/icons/Icon.astro";

interface Props {
  rank: number;
  label: string;
  href: string;
  meta: string;
}

const { rank, label, href, meta } = Astro.props;
const displayRank = String(rank).padStart(2, "0");
---

<a
  class="group grid grid-cols-[36px_1fr_auto] items-center gap-[11px] rounded-[11px] border-b border-slate-200 px-2 py-[15px] no-underline hover:bg-slate-50"
  href={href}
>
  <span class="text-[19px] font-extrabold tracking-[-0.04em] text-slate-400">{displayRank}</span>
  <div>
    <h3 class="m-0 mb-1 text-sm leading-[1.35] font-bold text-slate-900">{label}</h3>
    <p class="m-0 text-[11px] text-slate-500">{meta}</p>
  </div>
  <Icon
    name="arrow"
    class="size-4 text-slate-400 transition-transform duration-200 group-hover:translate-x-0.5"
  />
</a>
