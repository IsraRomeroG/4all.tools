---
import "@styles/global.css";
import Icon from "@components/icons/Icon.astro";
import BlogTextLink from "./BlogTextLink.astro";
import type { BlogLink } from "./types";

interface Props {
  title: string;
  symbol: string;
  description: string;
  links: BlogLink[];
  moreLabel: string;
  moreHref: string;
}

const { title, symbol, description, links, moreLabel, moreHref } = Astro.props;
---

<article
  class="flex min-h-full flex-col rounded-[22px] border border-slate-200 bg-white p-[25px] transition-[border-color,box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-[0_16px_40px_rgba(15,23,42,0.08)]"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="m-0 mb-2 text-[23px] font-bold tracking-[-0.035em] text-slate-900">{title}</h3>
    <span class="grid size-[38px] shrink-0 place-items-center rounded-[11px] bg-blue-50 text-[13px] font-black text-blue-700">
      {symbol}
    </span>
  </div>
  <p class="m-0 mb-5 text-sm leading-[1.65] text-slate-500">{description}</p>
  <div class="mb-[21px] grid">
    {
      links.map(({ label, href }) => (
        <a
          class="group/link flex items-center justify-between gap-3 border-b border-slate-200 py-3 text-sm font-semibold text-slate-700 no-underline hover:text-blue-700"
          href={href}
        >
          {label}
          <Icon
            name="arrow"
            class="size-[15px] text-slate-400 transition-transform duration-200 group-hover/link:translate-x-0.5"
          />
        </a>
      ))
    }
  </div>
  <BlogTextLink class="mt-auto" href={moreHref} label={moreLabel} />
</article>
