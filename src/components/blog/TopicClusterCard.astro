---
import "@styles/global.css";
import type { BlogLink } from "./types";

interface Props {
  title: string;
  description: string;
  links: BlogLink[];
}

const { title, description, links } = Astro.props;
---

<article
  class="rounded-[21px] border border-slate-200 bg-white p-[22px] transition-[border-color,box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-[0_16px_40px_rgba(15,23,42,0.08)]"
>
  <h3 class="m-0 mb-2 text-xl font-bold tracking-[-0.03em] text-slate-900">{title}</h3>
  <p class="m-0 mb-[17px] text-[13px] leading-[1.65] text-slate-500">{description}</p>
  <div class="flex flex-wrap gap-[7px]">
    {
      links.map(({ label, href }) => (
        <a
          class="rounded-full border border-slate-200 bg-slate-50 px-[9px] py-[7px] text-[11px] font-semibold text-slate-700 no-underline hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700"
          href={href}
        >
          {label}
        </a>
      ))
    }
  </div>
</article>
