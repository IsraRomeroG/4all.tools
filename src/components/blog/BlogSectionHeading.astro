---
import "@styles/global.css";
import BlogTextLink from "./BlogTextLink.astro";

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  id?: string;
  linkLabel?: string;
  linkHref?: string;
}

const { eyebrow, title, description, id, linkLabel, linkHref } = Astro.props;
---

<div class="mb-[26px] flex flex-wrap items-end justify-between gap-[18px]">
  <div>
    <p class="mb-2 text-xs font-extrabold tracking-[0.11em] text-blue-600 uppercase">
      {eyebrow}
    </p>
    <h2
      class="mb-[9px] text-[clamp(29px,4vw,42px)] leading-[1.12] font-bold tracking-[-0.045em] text-slate-900"
      id={id}
    >
      {title}
    </h2>
    {
      description && (
        <p class="m-0 max-w-[690px] text-[15px] leading-[1.7] text-slate-500">
          {description}
        </p>
      )
    }
  </div>
  {linkLabel && linkHref && <BlogTextLink href={linkHref} label={linkLabel} />}
</div>
