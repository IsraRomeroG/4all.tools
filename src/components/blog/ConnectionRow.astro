---
import "@styles/global.css";
import BlogButton from "./BlogButton.astro";

interface Props {
  category: string;
  title: string;
  tool: string;
  toolHref: string;
}

const { category, title, tool, toolHref } = Astro.props;
---

<article
  class="grid gap-3 rounded-2xl border border-transparent bg-slate-50 p-4 hover:border-blue-200 hover:bg-white min-[600px]:grid-cols-[1fr_auto] min-[600px]:items-center"
>
  <div>
    <small class="text-[10px] font-extrabold tracking-[0.08em] text-blue-600 uppercase">{category}</small>
    <h3 class="mt-[5px] mb-1 text-[15px] leading-[1.35] font-bold tracking-[-0.015em] text-slate-900">{title}</h3>
    <span class="text-xs text-slate-500">
      Connected tool: <strong class="text-slate-700">{tool}</strong>
    </span>
  </div>
  <BlogButton
    class="w-full min-h-[39px] px-[13px] text-xs min-[600px]:w-auto"
    href={toolHref}
    label="Open tool"
    variant="secondary"
    arrow
  />
</article>
