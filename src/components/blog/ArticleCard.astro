---
import "@styles/global.css";
import BlogTextLink from "./BlogTextLink.astro";

interface Props {
  category: string;
  symbol: string;
  title: string;
  href: string;
  description: string;
  readTime: string;
  updated: string;
  toolLabel: string;
  toolHref: string;
}

const {
  category,
  symbol,
  title,
  href,
  description,
  readTime,
  updated,
  toolLabel,
  toolHref,
} = Astro.props;
---

<article
  class="group flex min-h-full flex-col rounded-[20px] border border-slate-200 bg-white p-[21px] transition-[border-color,box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-[0_16px_40px_rgba(15,23,42,0.08)] min-[1024px]:p-6"
>
  <div class="flex items-center justify-between gap-3">
    <span class="rounded-full bg-blue-100 px-[9px] py-1.5 text-xs font-bold text-blue-700">
      {category}
    </span>
    <span class="grid size-[39px] place-items-center rounded-xl bg-blue-50 text-[11px] font-black text-blue-700">
      {symbol}
    </span>
  </div>
  <h3 class="mt-[19px] mb-[10px] text-xl leading-[1.34] font-bold tracking-[-0.026em] text-slate-900 group-hover:text-blue-700">
    <a class="no-underline" href={href}>{title}</a>
  </h3>
  <p class="m-0 mb-[19px] text-sm leading-[1.67] text-slate-500">{description}</p>
  <div class="mt-auto border-t border-slate-200 pt-4">
    <div class="mb-[11px] flex flex-wrap gap-x-3.5 gap-y-2 text-xs font-semibold text-slate-500">
      <span>{readTime}</span>
      <span>{updated}</span>
    </div>
    <BlogTextLink href={toolHref} label={toolLabel} />
  </div>
</article>
