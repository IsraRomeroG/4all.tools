---
import "@styles/global.css";
import BlogButton from "./BlogButton.astro";
import ToolSearchMockup from "./ToolSearchMockup.astro";
import type { ToolResult } from "./types";

interface Props {
  id?: string;
  category?: string;
  title?: string;
  description?: string;
  meta?: string[];
  href?: string;
  relatedHref?: string;
  mockupResults?: ToolResult[];
}

const {
  id,
  category = "Productivity",
  title = "How to choose the right online tool for any task",
  description = "A practical framework for finding calculators, converters, file utilities, SEO tools and developer helpers without wasting time switching between apps.",
  meta = ["8 min read", "Updated Jun 2026", "Beginner friendly"],
  href = "/blog/productivity/choose-the-right-online-tool/",
  relatedHref = "/tools/",
  mockupResults,
} = Astro.props;
---

<article
  class="relative grid gap-[30px] overflow-hidden rounded-[28px] border border-slate-200 bg-[linear-gradient(145deg,#fff,#eff6ff)] p-[25px] shadow-[0_16px_48px_rgba(15,23,42,0.08)] before:absolute before:top-[-180px] before:left-[-190px] before:size-[280px] before:rounded-full before:border before:border-blue-600/15 min-[768px]:p-[34px] min-[1024px]:grid-cols-[1.08fr_0.92fr] min-[1024px]:rounded-[32px] min-[1024px]:p-11"
>
  <div class="relative flex flex-col items-start justify-center">
    <span class="rounded-full bg-blue-100 px-[9px] py-1.5 text-xs font-bold text-blue-700">
      {category}
    </span>
    <h2
      class="mt-[17px] mb-[13px] max-w-[620px] text-[clamp(29px,4vw,40px)] leading-[1.13] font-bold tracking-[-0.045em] text-slate-900"
      id={id}
    >
      {title}
    </h2>
    <p class="m-0 max-w-[630px] text-base leading-[1.7] text-slate-700">{description}</p>
    <div class="my-5 flex flex-wrap gap-x-3.5 gap-y-2 text-xs font-semibold text-slate-500">
      {meta.map((item) => <span>{item}</span>)}
    </div>
    <div class="flex flex-wrap gap-[9px]">
      <BlogButton href={href} label="Read guide" arrow />
      <BlogButton href={relatedHref} label="Explore related tools" variant="secondary" />
    </div>
  </div>
  <ToolSearchMockup results={mockupResults} />
</article>
