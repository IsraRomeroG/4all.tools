---
import "./d1.css";

interface Props {
  kicker: string;
  title: string;
  description?: string;
  align?: "split" | "centered";
}

const { kicker, title, description, align = "split" } = Astro.props;
---

<div class:list={["d1-section-heading", `d1-section-heading-${align}`]}>
  <div>
    <span class="d1-kicker">{kicker}</span>
    <h2>{title}</h2>
  </div>
  {description && <p>{description}</p>}
</div>
