  image:
    '<rect x="3" y="4" width="18" height="16" rx="2.5"></rect><circle cx="8.5" cy="9" r="1.5"></circle><path d="m4 17 5-5 4 4 2-2 5 4"></path>',
  text: '<path d="M4 6h16M9 6v13M15 6v13M6 19h6M12 19h6"></path>',
