  qr: '<path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h2v2h-2zM18 14h2v6h-4v-2h-2v2"></path>',
  rocket:
    '<path d="M14 4c3-2 6-2 6-2s0 3-2 6l-6 6-4-4zM8 10l-4 2-2 4 6-1M12 14l-1 6 4-2 2-4M6 18l-3 3"></path><circle cx="15.5" cy="6.5" r="1.5"></circle>',
  arrow: '<path d="M5 12h14m-5-5 5 5-5 5"></path>',
