---
import "./d1.css";
import Icon from "./Icon.astro";
import type { ToolItem } from "./types";

type Props = ToolItem;

const { title, description, badge, icon, tone, href } = Astro.props;
---

<article class="d1-tool-card">
  <div class="d1-tool-top">
    <span class:list={["d1-icon-box", "d1-icon-box-large", `d1-tone-${tone}`]}>
      <Icon name={icon} />
    </span>
    <span class="d1-badge">{badge}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <a href={href}>
    Open tool
    <Icon name="arrow" />
  </a>
</article>
