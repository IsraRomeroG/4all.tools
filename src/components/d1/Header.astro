---
import "./d1.css";
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import type { LinkItem } from "./types";

interface Props {
  homeHref?: string;
  links?: LinkItem[];
}

const defaultLinks: LinkItem[] = [
  { label: "Tools", href: "#featured" },
  { label: "Categories", href: "#categories" },
  { label: "SEO", href: "#browse" },
  { label: "Calculators", href: "#popular" },
  { label: "Converters", href: "#featured" },
  { label: "PDF", href: "#browse" },
];

const { homeHref = "/", links = defaultLinks } = Astro.props;
---

<header class="d1-site-header" data-d1-header>
  <nav class="d1-nav d1-shell" aria-label="Main navigation">
    <Logo href={homeHref} />

    <div class="d1-nav-links">
      {links.map(({ label, href }) => <a href={href}>{label}</a>)}
    </div>

    <button class="d1-nav-search" type="button" data-focus-search>
      <Icon name="search" />
      <span>Search tools</span>
      <kbd>&#8984; K</kbd>
    </button>

    <button
      class="d1-menu-button"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="d1-mobile-menu"
    >
      <Icon class="d1-menu-icon" name="menu" />
      <Icon class="d1-close-icon" name="close" />
    </button>
  </nav>

  <div class="d1-mobile-menu d1-shell" id="d1-mobile-menu">
    {links.map(({ label, href }) => <a href={href}>{label}</a>)}
  </div>
</header>

<script>
  document.querySelectorAll<HTMLElement>("[data-d1-header]").forEach((header) => {
    const menuButton = header.querySelector<HTMLButtonElement>(".d1-menu-button");
    const mobileMenu = header.querySelector<HTMLElement>(".d1-mobile-menu");
    const searchButton = header.querySelector<HTMLButtonElement>("[data-focus-search]");

    const updateScrollState = () => header.classList.toggle("d1-scrolled", window.scrollY > 20);
    updateScrollState();
    window.addEventListener("scroll", updateScrollState, { passive: true });

    searchButton?.addEventListener("click", () => {
      const search = document.querySelector<HTMLInputElement>("#tool-search");
      search?.focus();
      search?.scrollIntoView({ behavior: "smooth", block: "center" });
    });

    menuButton?.addEventListener("click", () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      menuButton.setAttribute("aria-expanded", String(!isOpen));
      menuButton.setAttribute("aria-label", isOpen ? "Open navigation" : "Close navigation");
      mobileMenu?.classList.toggle("d1-open", !isOpen);
    });

    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menuButton?.setAttribute("aria-expanded", "false");
        menuButton?.setAttribute("aria-label", "Open navigation");
        mobileMenu.classList.remove("d1-open");
      });
    });
  });
</script>
