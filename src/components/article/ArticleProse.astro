---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={[
    "min-w-0 text-[17px] leading-[1.78] text-slate-700 min-[900px]:text-lg min-[900px]:leading-[1.8]",
    "[&_h2]:mt-16 [&_h2]:mb-5 [&_h2]:text-[28px] [&_h2]:leading-[1.17] [&_h2]:font-extrabold [&_h2]:text-slate-900 min-[900px]:[&_h2]:text-4xl",
    "[&_h2:first-of-type]:mt-0 [&_h3]:mt-[38px] [&_h3]:mb-3.5 [&_h3]:text-[22px] [&_h3]:leading-[1.3] [&_h3]:font-extrabold [&_h3]:text-slate-900 min-[900px]:[&_h3]:text-[25px]",
    "[&_p]:mt-0 [&_p]:mb-[22px] [&_a]:font-semibold [&_a]:text-blue-700 [&_a]:underline [&_a]:decoration-blue-200 [&_a]:underline-offset-3 [&_a:hover]:decoration-blue-600",
    "[&_ul]:mt-0 [&_ul]:mb-6 [&_ul]:pl-[25px] [&_li]:my-2.5 [&_li]:pl-1 [&_li::marker]:text-blue-600",
    className,
  ]}
>
  <slot />
</div>
