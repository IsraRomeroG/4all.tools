---
import type { ArticleCalculationRow } from "./types";

interface Props {
  title: string;
  label?: string;
  rows: ArticleCalculationRow[];
}

const { title, label = "Worked example", rows } = Astro.props;
---

<div class="my-7 overflow-hidden rounded-[20px] border border-slate-200 bg-white">
  <div class="flex items-center justify-between gap-3 border-b border-slate-200 bg-slate-50 px-[18px] py-4">
    <strong class="text-sm text-slate-900">{title}</strong>
    <span class="text-xs text-slate-500">{label}</span>
  </div>
  <div class="grid px-[18px] py-2 font-mono text-sm">
    {
      rows.map((row, index) => (
        <div
          class:list={[
            "flex justify-between gap-[18px] border-b border-slate-200 py-3 max-[639px]:grid max-[639px]:gap-1",
            index === rows.length - 1 && "border-b-0 text-blue-700 font-extrabold",
          ]}
        >
          <span>{row.label}</span>
          <strong>{row.value}</strong>
        </div>
      ))
    }
  </div>
</div>
