---
import type { ArticleStepItem } from "./types";

interface Props {
  steps: ArticleStepItem[];
}

const { steps } = Astro.props;
---

<div class="my-7 grid gap-3">
  {
    steps.map((step, index) => (
      <div class="grid grid-cols-[42px_1fr] gap-3.5 rounded-[17px] border border-slate-200 bg-white p-[18px]">
        <span class="grid size-[38px] place-items-center rounded-full bg-blue-600 text-sm font-extrabold text-white">
          {index + 1}
        </span>
        <div>
          <h3 class="mt-0.5 mb-1 text-[17px] font-extrabold text-slate-900">{step.title}</h3>
          <p class="m-0 text-[15px] leading-[1.6] text-slate-500">{step.description}</p>
        </div>
      </div>
    ))
  }
</div>
