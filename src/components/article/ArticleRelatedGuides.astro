---
import ArticleSection from "./ArticleSection.astro";
import type { ArticleGuideCard } from "./types";

interface Props {
  eyebrow?: string;
  title?: string;
  titleId?: string;
  description?: string;
  actionLabel?: string;
  actionHref?: string;
  guides: ArticleGuideCard[];
}

const {
  eyebrow = "Continue learning",
  title = "Related guides",
  titleId = "articles-title",
  description = "Clear explanations for everyday calculations.",
  actionLabel = "Visit the blog",
  actionHref = "/blog/",
  guides,
} = Astro.props;
---

<ArticleSection
  eyebrow={eyebrow}
  title={title}
  titleId={titleId}
  description={description}
  actionLabel={actionLabel}
  actionHref={actionHref}
>
  <div class="grid gap-3.5 sm:grid-cols-3">
    {
      guides.map(({ category, title, description, href, meta }) => (
        <a
          class="flex min-h-full flex-col rounded-[19px] border border-slate-200 bg-white p-5 no-underline transition-[border-color,transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-[0_12px_30px_rgba(15,23,42,0.06)] motion-reduce:transform-none"
          href={href}
        >
          <span class="text-[11px] font-extrabold text-blue-600 uppercase">{category}</span>
          <h3 class="mt-3 mb-2 text-lg leading-[1.35] font-extrabold text-slate-900">{title}</h3>
          <p class="mt-0 mb-[18px] text-[13px] leading-[1.6] text-slate-500">{description}</p>
          <span class="mt-auto text-xs font-semibold text-slate-400">{meta}</span>
        </a>
      ))
    }
  </div>
</ArticleSection>
