---
import Icon from "@components/icons/Icon.astro";
import type { ArticleFaqItem } from "./types";

interface Props {
  items: ArticleFaqItem[];
}

const { items } = Astro.props;
---

<div class="mt-[26px] grid gap-2.5">
  {
    items.map(({ question, answer }) => (
      <details class="rounded-2xl border border-slate-200 bg-white open:border-slate-300">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-[18px] py-[17px] text-[15px] font-bold text-slate-900 marker:hidden">
          {question}
          <Icon name="plus" class="summary-icon size-4 text-blue-600 transition-transform duration-200" />
        </summary>
        <div class="px-[18px] pb-[18px] text-[15px] leading-[1.7] text-slate-500">{answer}</div>
      </details>
    ))
  }
</div>

<style>
  details[open] .summary-icon {
    transform: rotate(45deg);
  }
</style>
