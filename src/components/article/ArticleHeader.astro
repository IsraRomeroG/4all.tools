---
import Icon from "@components/icons/Icon.astro";
import type { ArticleLink } from "./types";

interface Props {
  homeHref?: string;
  links?: ArticleLink[];
  searchHref?: string;
}

const defaultLinks: ArticleLink[] = [
  { label: "Tools", href: "/tools/" },
  { label: "Categories", href: "/categories/" },
  { label: "SEO", href: "/categories/seo/" },
  { label: "Calculators", href: "/categories/calculators/" },
  { label: "PDF", href: "/categories/pdf/" },
  { label: "Converters", href: "/categories/converters/" },
];

const { homeHref = "/", links = defaultLinks, searchHref = "/tools/" } = Astro.props;
---

<header
  class="sticky top-0 z-50 h-16 border-b border-slate-200/90 bg-white/90 font-[Inter,ui-sans-serif,system-ui,sans-serif] backdrop-blur-[14px] min-[900px]:h-[72px]"
  data-article-header
>
  <div
    class="mx-auto flex h-full w-[min(1180px,calc(100%-40px))] items-center justify-between gap-6 max-[639px]:w-[min(1180px,calc(100%-32px))]"
  >
    <a
      class="inline-flex items-center gap-2 text-[19px] font-extrabold text-slate-900 no-underline"
      href={homeHref}
      aria-label="4all.tools home"
    >
      <span class="size-2.5 rounded-[3px] bg-blue-600 shadow-[0_0_0_4px_#eff6ff]" aria-hidden="true"></span>
      4all.tools
    </a>

    <nav class="hidden items-center gap-1.5 min-[900px]:flex" aria-label="Main navigation">
      {
        links.map(({ label, href }) => (
          <a
            class="rounded-[9px] px-[11px] py-[9px] text-sm font-semibold text-slate-500 no-underline hover:bg-slate-50 hover:text-slate-900"
            href={href}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        class="hidden min-h-[42px] items-center gap-2.5 rounded-[11px] border border-slate-200 bg-white px-3 text-[13px] text-slate-500 no-underline hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900 min-[900px]:inline-flex"
        href={searchHref}
        aria-label="Search tools"
      >
        <Icon name="search-compact" class="size-5" />
        Search tools <kbd class="rounded-[5px] border border-slate-200 bg-slate-50 px-1.5 py-0.5 text-[11px] text-slate-500">/</kbd>
      </a>
      <a
        class="grid size-[42px] place-items-center rounded-[11px] border border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900"
        href={searchHref}
        aria-label="Search"
      >
        <Icon name="search-compact" class="size-5" />
      </a>
      <button
        class="grid size-[42px] place-items-center rounded-[11px] border border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900 min-[900px]:hidden"
        type="button"
        aria-expanded="false"
        aria-controls="article-mobile-menu"
        aria-label="Open navigation"
        data-article-menu-button
      >
        <Icon name="menu" class="size-5" />
      </button>
    </div>

    <nav
      class="absolute inset-x-0 top-16 hidden border-b border-slate-200 bg-white px-5 pt-3 pb-5 shadow-[0_18px_50px_rgba(15,23,42,0.07)] data-[open=true]:grid min-[900px]:!hidden"
      id="article-mobile-menu"
      aria-label="Mobile navigation"
      data-article-mobile-menu
      data-open="false"
    >
      {
        links.map(({ label, href }) => (
          <a
            class="border-b border-slate-200 px-2 py-[13px] text-[15px] font-semibold text-slate-700 no-underline"
            href={href}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  document.querySelectorAll<HTMLElement>("[data-article-header]").forEach((header) => {
    const button = header.querySelector<HTMLButtonElement>("[data-article-menu-button]");
    const menu = header.querySelector<HTMLElement>("[data-article-mobile-menu]");

    button?.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!isOpen));
      button.setAttribute("aria-label", isOpen ? "Open navigation" : "Close navigation");
      if (menu) menu.dataset.open = String(!isOpen);
    });
  });
</script>
