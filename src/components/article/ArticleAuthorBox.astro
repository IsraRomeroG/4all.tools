---
import Icon from "@components/icons/Icon.astro";
import type { ArticleAuthor } from "./types";

interface Props {
  author: ArticleAuthor;
}

const { author } = Astro.props;
---

<aside
  class="mt-[42px] grid grid-cols-[auto_1fr] gap-4 rounded-[22px] border border-slate-200 bg-slate-50 p-[22px]"
  aria-label="Article author"
>
  <div class="grid size-12 place-items-center rounded-[14px] bg-slate-900 text-sm font-extrabold text-white" aria-hidden="true">
    {author.initials}
  </div>
  <div>
    <h3 class="m-0 mb-1.5 text-base font-extrabold text-slate-900">{author.name}</h3>
    <p class="m-0 text-[13px] leading-[1.65] text-slate-500">{author.description}</p>
    {
      author.reviewedLabel && (
        <span class="mt-2 inline-flex items-center gap-1.5 text-xs font-bold text-green-700">
          <Icon name="check" class="size-3.5" />
          {author.reviewedLabel}
        </span>
      )
    }
  </div>
</aside>
