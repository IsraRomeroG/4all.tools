---
import Icon from "@components/icons/Icon.astro";
import type { ArticleLink } from "./types";

interface Props {
  eyebrow?: string;
  title?: string;
  titleId?: string;
  description?: string;
  action?: string;
  placeholder?: string;
  buttonLabel?: string;
  suggestions?: ArticleLink[];
}

const defaultSuggestions: ArticleLink[] = [
  { label: "PDF to Word", href: "/tools/pdf-to-word/" },
  { label: "JSON Formatter", href: "/tools/json-formatter/" },
  { label: "BMI Calculator", href: "/tools/bmi-calculator/" },
  { label: "Image Compressor", href: "/tools/image-compressor/" },
];

const {
  eyebrow = "One place. Every tool.",
  title = "Need another tool?",
  titleId = "search-title",
  description = "Search calculators, converters, PDF tools, SEO utilities, and more.",
  action = "/search/",
  placeholder = "Search tools...",
  buttonLabel = "Search tools",
  suggestions = defaultSuggestions,
} = Astro.props;
---

<section
  class="mx-auto w-[min(1180px,calc(100%-40px))] py-[70px] max-[639px]:w-[min(1180px,calc(100%-32px))]"
  aria-labelledby={titleId}
>
  <div class="relative overflow-hidden rounded-[28px] border border-slate-200 bg-gradient-to-br from-slate-50 to-blue-50 px-6 py-[34px] text-center min-[900px]:px-[30px] min-[900px]:py-[58px]">
    <p class="mt-0 mb-2 text-xs font-extrabold text-blue-600 uppercase">{eyebrow}</p>
    <h2 id={titleId} class="m-0 mb-2.5 text-3xl font-extrabold text-slate-900 min-[900px]:text-[44px]">{title}</h2>
    <p class="mx-auto mt-0 mb-6 max-w-[570px] text-[15px] leading-[1.6] text-slate-500">{description}</p>

    <form
      class="mx-auto grid max-w-[610px] rounded-[14px] border border-slate-300 bg-white p-[7px] shadow-[0_12px_30px_rgba(15,23,42,0.08)] sm:flex sm:p-[5px]"
      action={action}
      role="search"
    >
      <label class="flex min-w-0 flex-1 items-center gap-2.5 px-2 text-slate-500 sm:pl-[11px]">
        <Icon name="search-compact" class="size-5" />
        <input
          class="h-11 w-full min-w-0 border-0 bg-transparent text-slate-900 outline-0"
          type="search"
          name="q"
          placeholder={placeholder}
          aria-label={buttonLabel}
        />
      </label>
      <button
        class="inline-flex min-h-11 items-center justify-center rounded-xl border border-blue-600 bg-blue-600 px-[18px] text-sm font-bold text-white hover:border-blue-700 hover:bg-blue-700 max-[639px]:w-full"
        type="submit"
      >
        {buttonLabel}
      </button>
    </form>

    <div class="mt-[18px] flex flex-wrap justify-center gap-2" aria-label="Popular searches">
      {
        suggestions.map(({ label, href }) => (
          <a
            class="rounded-full border border-slate-200 bg-white/70 px-2.5 py-1.5 text-xs font-semibold text-slate-500 no-underline hover:border-blue-200 hover:text-blue-600"
            href={href}
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</section>
