---
import Icon from "@components/icons/Icon.astro";
import type { ArticleTocItem } from "./types";

interface Props {
  items: ArticleTocItem[];
  title?: string;
}

const { items, title = "On this page" } = Astro.props;
---

<details class="mb-[38px] rounded-2xl border border-slate-200 bg-white min-[900px]:hidden">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-[18px] py-[17px] font-bold text-slate-900 marker:hidden">
    {title}
    <Icon name="plus" class="summary-icon size-4 text-blue-600 transition-transform duration-200" />
  </summary>
  <nav class="grid gap-3 px-[18px] pb-[18px]" aria-label="Mobile table of contents">
    {
      items.map(({ label, href }) => (
        <a class="text-sm leading-[1.4] text-slate-500 no-underline hover:text-blue-600" href={href}>
          {label}
        </a>
      ))
    }
  </nav>
</details>

<style>
  details[open] .summary-icon {
    transform: rotate(45deg);
  }
</style>
