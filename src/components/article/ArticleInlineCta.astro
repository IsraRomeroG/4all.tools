---
import ArticleButton from "./ArticleButton.astro";

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  href: string;
  ctaLabel: string;
}

const { eyebrow = "Calculate instantly", title, description, href, ctaLabel } = Astro.props;
---

<div class="relative my-7 grid gap-[18px] overflow-hidden rounded-[20px] border border-blue-200 bg-gradient-to-br from-blue-50 to-white p-6 sm:grid-cols-[1fr_auto] sm:items-center sm:p-7">
  <span class="pointer-events-none absolute top-[-28px] right-[22px] text-[130px] leading-none font-black text-blue-600/10" aria-hidden="true">%</span>
  <div class="relative z-10">
    <p class="mt-0 mb-2 text-xs font-extrabold text-blue-600 uppercase">{eyebrow}</p>
    <h3 class="m-0 mb-1.5 text-[22px] font-extrabold text-slate-900">{title}</h3>
    <p class="m-0 max-w-[500px] text-[15px] leading-[1.7] text-slate-700">{description}</p>
  </div>
  <ArticleButton href={href} label={ctaLabel} arrow class="relative z-10 w-fit max-[639px]:w-full" />
</div>
