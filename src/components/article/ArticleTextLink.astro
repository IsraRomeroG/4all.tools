---
import Icon from "@components/icons/Icon.astro";

interface Props {
  href: string;
  label: string;
  class?: string;
}

const { href, label, class: className } = Astro.props;
---

<a
  class:list={[
    "group/article-link inline-flex items-center gap-1.5 text-sm font-bold text-blue-600 no-underline focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-blue-600/40",
    className,
  ]}
  href={href}
>
  {label}
  <Icon
    name="arrow-right-long"
    class="size-4 transition-transform duration-200 group-hover/article-link:translate-x-0.5 motion-reduce:transform-none"
  />
</a>
