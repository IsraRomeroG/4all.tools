---
import ArticleTextLink from "./ArticleTextLink.astro";

interface Props {
  eyebrow?: string;
  title: string;
  titleId?: string;
  description?: string;
  actionLabel?: string;
  actionHref?: string;
  soft?: boolean;
}

const {
  eyebrow,
  title,
  titleId,
  description,
  actionLabel,
  actionHref,
  soft = false,
} = Astro.props;
---

<section
  class:list={[
    "border-t border-slate-200 py-[78px] min-[900px]:py-[94px]",
    soft && "bg-slate-50",
  ]}
  aria-labelledby={titleId}
>
  <div class="mx-auto w-[min(1180px,calc(100%-40px))] max-[639px]:w-[min(1180px,calc(100%-32px))]">
    <div class="mb-[30px] flex flex-wrap items-end justify-between gap-[18px]">
      <div>
        {eyebrow && <p class="mt-0 mb-2 text-xs font-extrabold text-blue-600 uppercase">{eyebrow}</p>}
        <h2 id={titleId} class="m-0 mb-2 text-[28px] leading-[1.15] font-extrabold text-slate-900 min-[900px]:text-[38px]">
          {title}
        </h2>
        {description && <p class="m-0 text-[15px] leading-[1.6] text-slate-500">{description}</p>}
      </div>
      {actionLabel && actionHref && <ArticleTextLink href={actionHref} label={actionLabel} />}
    </div>
    <slot />
  </div>
</section>
