---
import ArticleButton from "./ArticleButton.astro";
import ArticleIconBox from "./ArticleIconBox.astro";
import type { ArticleAction } from "./types";
import type { IconName } from "@components/icons/iconNames";

interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  description: string;
  formula: string;
  icon?: IconName;
  actions?: ArticleAction[];
}

const {
  id = "quick-answer",
  eyebrow = "The short version",
  title = "Quick answer",
  description,
  formula,
  icon = "lightbulb",
  actions = [],
} = Astro.props;

const titleId = `${id}-title`;
---

<section
  class="mx-auto grid w-[min(1180px,calc(100%-40px))] gap-[22px] rounded-[24px] border border-blue-200 bg-gradient-to-br from-blue-50 to-white p-[26px] max-[639px]:w-[min(1180px,calc(100%-32px))] sm:grid-cols-[1fr_auto] sm:items-center sm:p-[30px] min-[900px]:p-9"
  id={id}
  aria-labelledby={titleId}
>
  <div>
    <p class="mt-0 mb-2 text-xs font-extrabold text-blue-600 uppercase">{eyebrow}</p>
    <h2 id={titleId} class="mt-1 mb-2.5 text-2xl font-extrabold text-slate-900">{title}</h2>
    <p class="m-0 text-base leading-[1.7] text-slate-700">{description}</p>
  </div>

  <ArticleIconBox icon={icon} />

  <div class="overflow-x-auto rounded-2xl border border-blue-200 bg-white/85 p-[18px] font-mono text-sm leading-[1.6] font-bold text-slate-900 sm:col-span-full">
    {formula}
  </div>

  {
    actions.length > 0 && (
      <div class="flex flex-wrap gap-2.5 sm:col-span-full">
        {actions.map((action) => (
          <ArticleButton
            href={action.href}
            label={action.label}
            variant={action.variant ?? "primary"}
            class="max-[639px]:w-full"
          />
        ))}
      </div>
    )
  }
</section>
