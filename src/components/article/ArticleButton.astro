---
import Icon from "@components/icons/Icon.astro";

interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  arrow?: boolean;
  class?: string;
}

const {
  href,
  label,
  variant = "primary",
  arrow = false,
  class: className,
} = Astro.props;

const variants = {
  primary:
    "border-blue-600 bg-blue-600 text-white hover:border-blue-700 hover:bg-blue-700",
  secondary:
    "border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900",
} satisfies Record<NonNullable<Props["variant"]>, string>;
---

<a
  class:list={[
    "inline-flex min-h-[46px] items-center justify-center gap-2 rounded-xl border px-[18px] text-sm font-bold no-underline transition-[color,background-color,border-color,transform] duration-200 hover:-translate-y-px focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-blue-600/40 motion-reduce:transform-none",
    variants[variant],
    className,
  ]}
  href={href}
>
  {label}
  {arrow && <Icon name="arrow-right-long" class="size-4" />}
</a>
