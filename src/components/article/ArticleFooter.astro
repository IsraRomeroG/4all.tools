---
import type { ArticleFooterGroup } from "./types";

interface Props {
  homeHref?: string;
  groups?: ArticleFooterGroup[];
}

const defaultGroups: ArticleFooterGroup[] = [
  {
    title: "Tools",
    links: [
      { label: "Calculators", href: "/categories/calculators/" },
      { label: "SEO Tools", href: "/categories/seo/" },
      { label: "PDF Tools", href: "/categories/pdf/" },
      { label: "Converters", href: "/categories/converters/" },
      { label: "Developer Tools", href: "/categories/developer-tools/" },
    ],
  },
  {
    title: "Categories",
    links: [
      { label: "Finance", href: "/categories/finance/" },
      { label: "Images", href: "/categories/images/" },
      { label: "Text", href: "/categories/text/" },
      { label: "Date & Time", href: "/categories/date-time/" },
      { label: "Education", href: "/categories/education/" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blog", href: "/blog/" },
      { label: "Popular Tools", href: "/popular-tools/" },
      { label: "New Tools", href: "/new-tools/" },
      { label: "Guides", href: "/guides/" },
      { label: "Sitemap", href: "/sitemap/" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/about/" },
      { label: "Contact", href: "/contact/" },
      { label: "Privacy", href: "/privacy/" },
      { label: "Terms", href: "/terms/" },
    ],
  },
];

const { homeHref = "/", groups = defaultGroups } = Astro.props;
---

<footer class="bg-slate-950 pt-[60px] pb-6 text-slate-300">
  <div class="mx-auto w-[min(1180px,calc(100%-40px))] max-[639px]:w-[min(1180px,calc(100%-32px))]">
    <div class="grid gap-9 min-[900px]:grid-cols-[1.1fr_2fr] min-[900px]:gap-16">
      <div>
        <a
          class="inline-flex items-center gap-2 text-[19px] font-extrabold text-white no-underline"
          href={homeHref}
          aria-label="4all.tools home"
        >
          <span class="size-2.5 rounded-[3px] bg-blue-500 shadow-[0_0_0_4px_rgba(37,99,235,0.18)]" aria-hidden="true"></span>
          4all.tools
        </a>
        <p class="mt-4 mb-0 max-w-[360px] text-[13px] leading-[1.7] text-slate-400">
          Fast, focused online tools for calculations, conversions, files, SEO, and everyday work.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-x-5 gap-y-7 min-[640px]:grid-cols-4">
        {
          groups.map(({ title, links }) => (
            <div>
              <h3 class="m-0 mb-3 text-xs font-extrabold text-white uppercase">{title}</h3>
              {links.map(({ label, href }) => (
                <a class="my-2 block text-[13px] text-slate-400 no-underline hover:text-white" href={href}>
                  {label}
                </a>
              ))}
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-5 text-xs text-slate-500 min-[640px]:flex-row min-[640px]:items-center min-[640px]:justify-between">
      <span>&copy; 2026 4all.tools. Free online tools for everyone.</span>
      <span>Built for speed, clarity, and useful answers.</span>
    </div>
  </div>
</footer>
