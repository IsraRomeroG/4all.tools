---
import "@styles/global.css";

interface Props {
  href?: string;
  label?: string;
  markShadow?: boolean;
  variant?: "dark" | "light";
}

const {
  href = "/",
  label = "4all.tools home",
  markShadow = true,
  variant = "dark",
} = Astro.props;

const variantClasses = {
  dark: "text-slate-900",
  light: "text-white",
} satisfies Record<NonNullable<Props["variant"]>, string>;
---

<a
  class:list={[
    "inline-flex items-center gap-2.5 font-[Inter,ui-sans-serif,system-ui,sans-serif] text-xl leading-[1.6] font-extrabold tracking-[-0.7px] no-underline antialiased focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-blue-600/35",
    variantClasses[variant],
  ]}
  href={href}
  aria-label={label}
>
  <span
    class:list={[
      "grid size-7 grid-cols-2 gap-0.5 rounded-lg bg-slate-900 p-[5px]",
      markShadow && "shadow-[0_5px_14px_#2563eb40]",
    ]}
    aria-hidden="true"
  >
    <span class="rounded-[1.5px] bg-white opacity-95"></span>
    <span class="rounded-[1.5px] bg-white opacity-95"></span>
    <span class="rounded-[1.5px] bg-white opacity-95"></span>
    <span class="rounded-[1.5px] bg-blue-400 opacity-95"></span>
  </span>
  <span>4all<span class="text-blue-500">.tools</span></span>
</a>
