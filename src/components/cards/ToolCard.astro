---
import "@styles/global.css";
import Icon from "@components/icons/Icon.astro";

interface Props {
  title: string;
  description: string;
  badge: string;
  icon:
    | "search"
    | "calculator"
    | "file"
    | "chart"
    | "code"
    | "sparkles"
    | "image"
    | "text"
    | "arrows"
    | "megaphone"
    | "book"
    | "briefcase"
    | "percent"
    | "calendar"
    | "qr"
    | "rocket"
    | "arrow"
    | "check"
    | "bolt"
    | "grid"
    | "menu"
    | "close";
  tone:
    | "blue"
    | "violet"
    | "red"
    | "green"
    | "slate"
    | "purple"
    | "pink"
    | "amber"
    | "cyan"
    | "orange"
    | "indigo"
    | "emerald";
  href: string;
}

const { title, description, badge, icon, tone, href } = Astro.props;

const toneClasses = {
  blue: "bg-blue-50 text-blue-600",
  violet: "bg-violet-50 text-violet-600",
  red: "bg-red-50 text-red-600",
  green: "bg-green-50 text-green-600",
  slate: "bg-slate-100 text-slate-700",
  purple: "bg-purple-50 text-purple-600",
  pink: "bg-pink-50 text-pink-600",
  amber: "bg-amber-50 text-amber-600",
  cyan: "bg-cyan-50 text-cyan-600",
  orange: "bg-orange-50 text-orange-600",
  indigo: "bg-indigo-50 text-indigo-600",
  emerald: "bg-emerald-50 text-emerald-600",
} satisfies Record<Props["tone"], string>;
---

<article
  class="flex min-h-[290px] flex-col rounded-[18px] border border-slate-200 bg-white p-[25px] font-[Inter,ui-sans-serif,system-ui,sans-serif] leading-[1.6] text-slate-900 antialiased transition-[transform,box-shadow,border-color] duration-[250ms] hover:-translate-y-1 hover:border-[#cbdaf5] hover:shadow-[0_18px_45px_#0f172a14] motion-reduce:transform-none motion-reduce:transition-none max-[760px]:min-h-[270px]"
>
  <div class="flex items-start justify-between">
    <span class:list={["inline-flex size-[54px] items-center justify-center rounded-[15px]", toneClasses[tone]]}>
      <Icon name={icon} class="size-6" />
    </span>
    <span class="rounded-full border border-slate-200 px-2 py-[3px] text-[9px] font-extrabold tracking-[0.08em] text-slate-400 uppercase">
      {badge}
    </span>
  </div>
  <h3 class="mt-[22px] mb-2 text-[19px] leading-[1.3] font-bold tracking-[-0.025em] text-slate-900">{title}</h3>
  <p class="m-0 text-[13px] leading-[1.7] text-slate-600">{description}</p>
  <a
    class="group/link mt-auto flex items-center gap-[7px] pt-5 text-xs font-extrabold text-blue-600 no-underline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-blue-600/35"
    href={href}
  >
    Open tool
    <Icon
      name="arrow"
      class="size-[15px] transition-transform duration-200 group-hover/link:translate-x-[3px] motion-reduce:transform-none motion-reduce:transition-none"
    />
  </a>
</article>
