---
import type { LanguageSwitcherModel } from '@/navigation/language-switcher';

interface Props {
  model: LanguageSwitcherModel;
}

const { model } = Astro.props;
---

<nav
  class="border-b border-slate-200 bg-white px-4 py-2 sm:px-6 lg:px-8"
  aria-label={model.ariaLabel}
  data-language-switcher
>
  <ul class="mx-auto flex w-full max-w-6xl flex-wrap items-center gap-x-4 gap-y-2 text-sm">
    {
      model.items.map((item) => (
        <li data-locale={item.locale} data-state={item.state}>
          {
            item.state === 'available' ? (
              <a
                class="text-slate-700 underline decoration-transparent underline-offset-4 hover:text-slate-950 hover:decoration-slate-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-700"
                href={item.url}
                hreflang={item.htmlLang}
                lang={item.htmlLang}
              >
                {item.label}
              </a>
            ) : item.state === 'current' ? (
              <span class="font-semibold text-slate-950" aria-current="page" lang={item.htmlLang}>
                {item.label}
                <span class="sr-only"> ({model.currentLanguage})</span>
              </span>
            ) : (
              <span class="text-slate-500" aria-disabled="true" lang={item.htmlLang}>
                {item.label}
                <span class="sr-only"> ({model.unavailableLabel})</span>
              </span>
            )
          }
        </li>
      ))
    }
  </ul>
</nav>
