---
import "@styles/global.css";

interface Props {
  kicker: string;
  title: string;
  description?: string;
  align?: "split" | "centered";
}

const { kicker, title, description, align = "split" } = Astro.props;

const alignmentClasses = {
  split: "flex items-end justify-between gap-[60px] max-[760px]:block",
  centered: "mx-auto max-w-[680px] text-center",
} satisfies Record<NonNullable<Props["align"]>, string>;

const descriptionClasses = {
  split: "mt-[17px] mb-1 max-w-[480px] max-[760px]:mt-3.5",
  centered: "mt-[17px] mb-0",
} satisfies Record<NonNullable<Props["align"]>, string>;
---

<div
  class:list={[
    "mb-[50px] font-[Inter,ui-sans-serif,system-ui,sans-serif] leading-[1.6] text-slate-900 antialiased max-[760px]:mb-8",
    alignmentClasses[align],
  ]}
>
  <div>
    <span class="mb-2.5 block text-xs font-extrabold tracking-[0.13em] text-blue-600 uppercase">{kicker}</span>
    <h2 class="m-0 text-[clamp(36px,4vw,48px)] leading-[1.12] font-bold tracking-[-0.045em] max-[760px]:text-[34px]">
      {title}
    </h2>
  </div>
  {
    description && (
      <p
        class:list={[
          "text-[17px] leading-[1.7] text-slate-600 max-[760px]:text-sm",
          descriptionClasses[align],
        ]}
      >
        {description}
      </p>
    )
  }
</div>
