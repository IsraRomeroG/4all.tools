---
import "@styles/global.css";
import ButtonLink from "@components/buttons/ButtonLink.astro";
import SectionHeading from "@components/sections/SectionHeading.astro";
import ToolCard from "@components/cards/ToolCard.astro";

interface ToolItem {
  title: string;
  description: string;
  badge: string;
  icon:
    | "search"
    | "calculator"
    | "file"
    | "chart"
    | "code"
    | "sparkles"
    | "image"
    | "text"
    | "arrows"
    | "megaphone"
    | "book"
    | "briefcase"
    | "percent"
    | "calendar"
    | "qr"
    | "rocket"
    | "arrow"
    | "check"
    | "bolt"
    | "grid"
    | "menu"
    | "close";
  tone:
    | "blue"
    | "violet"
    | "red"
    | "green"
    | "slate"
    | "purple"
    | "pink"
    | "amber"
    | "cyan"
    | "orange"
    | "indigo"
    | "emerald";
  href: string;
}

interface Props {
  tools?: ToolItem[];
}

const defaultTools: ToolItem[] = [
  {
    title: "Percentage Calculator",
    description: "Calculate percentages, changes, and differences in seconds.",
    badge: "Popular",
    icon: "percent",
    tone: "blue",
    href: "#featured",
  },
  {
    title: "PDF to Word",
    description: "Convert PDF documents into editable Word files instantly.",
    badge: "Fast",
    icon: "file",
    tone: "red",
    href: "#featured",
  },
  {
    title: "Image Compressor",
    description: "Reduce image size while keeping every detail crisp.",
    badge: "Private",
    icon: "image",
    tone: "pink",
    href: "#featured",
  },
  {
    title: "JSON Formatter",
    description: "Format, validate, and inspect JSON without the friction.",
    badge: "Developer",
    icon: "code",
    tone: "slate",
    href: "#featured",
  },
  {
    title: "Age Calculator",
    description: "Find exact age in years, months, days, and even minutes.",
    badge: "Easy",
    icon: "calendar",
    tone: "violet",
    href: "#featured",
  },
  {
    title: "QR Code Generator",
    description: "Create clean, scannable QR codes for any destination.",
    badge: "Free",
    icon: "qr",
    tone: "indigo",
    href: "#featured",
  },
  {
    title: "Loan Calculator",
    description: "Estimate payments, interest, and your payoff timeline.",
    badge: "Finance",
    icon: "chart",
    tone: "green",
    href: "#featured",
  },
  {
    title: "Word Counter",
    description: "Count words, characters, sentences, and reading time.",
    badge: "Writing",
    icon: "text",
    tone: "amber",
    href: "#featured",
  },
];

const { tools = defaultTools } = Astro.props;
---

<section
  class="border-y border-[#edf1f6] bg-slate-50 py-28 font-[Inter,ui-sans-serif,system-ui,sans-serif] leading-[1.6] text-slate-900 antialiased max-[760px]:py-[76px]"
  id="featured"
>
  <div class="mx-auto w-[calc(100%-40px)] max-w-[1280px] max-[760px]:w-[calc(100%-28px)] max-[760px]:max-w-[560px]">
    <SectionHeading
      kicker="Community favorites"
      title="Featured tools"
      description="Reliable, quick, and loved by millions. These are the tools people reach for every day."
    />

    <div class="grid grid-cols-4 gap-5 max-[1050px]:grid-cols-2 max-[760px]:grid-cols-1">
      {tools.map((tool) => <ToolCard {...tool} />)}
    </div>

    <div class="mt-[38px] text-center">
      <ButtonLink href="#browse" label="View all tools" variant="secondary" />
    </div>
  </div>
</section>
